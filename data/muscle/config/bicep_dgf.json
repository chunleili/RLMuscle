{
  "metainfo": {
    "description": "DGF (DeGroote-Fregly) constitutive muscle model with attachnormal constraints",
    "used_by": ["tests/test_mesh_quality.py"],
    "created": "2026-02-10",
    "_note": "Top-level contraction_ratio controls generic FIBER constraint. The 'fiberdgf' constraint has its own contraction_factor for DGF-specific logic. Both are set to 0.4 here."
  },
  "name": "bicep_dgf",
  "geo_path": "data/muscle/model/bicep.usd",
  "bone_geo_path": "data/muscle/model/bicep.usd",
  "ground_mesh_path": "data/muscle/model/ground.obj",
  "coord_mesh_path": "data/muscle/model/coord.obj",
  "contraction_ratio": 0.4,
  "fiber_stiffness_scale": 100000.0,
  "arch": "cpu",
  "save_image": false,
  "gui": true,
  "render_mode": "human",
  "dt": 0.041666666666666667,
  "nsteps": 10000,
  "num_substeps": 10,
  "gravity": 0.0,
  "density": 1000.0,
  "veldamping": 0.02,
  "activation": 0.0,
  "pause": true,
  "reset": false,
  "show_auxiliary_meshes": false,
  "show_wireframe": false,
  "render_fps": 24,
  "color_bones": false,
  "color_muscles": "tendonmask",
  "HAS_compressstiffness": false,
  "constraints": [
    {
      "type": "volume",
      "name": "volume",
      "stiffness": 1e10,
      "dampingratio": 0.1
    },
    {
      "type": "fiberdgf",
      "name": "fiber_dgf",
      "stiffness": 1000.0,
      "dampingratio": 0.1,
      "contraction_factor": 0.4
    },
    {
      "type":"tetarap",
      "name":"tetarap",
      "stiffness": 1e10,
      "dampingratio": 0.1
    },
    {
      "type": "attach",
      "name": "muscleToBonesAttach",
      "mask_name": "muscletobonemask",
      "mask_threshold": 0.75,
      "stiffness": 1e10,
      "dampingratio": 0.1,
      "target_path": "data/muscle/model/bicep_bone.geo"
    },
    {
      "type": "attachnormal",
      "name": "muscleEndAttachNormal",
      "mask_name": "muscleendmask",
      "mask_threshold": 0.75,
      "stiffness": 1e37,
      "dampingratio": 0.1,
      "target_path": "data/muscle/model/bicep_bone.geo"
    },
    {
      "type": "attach",
      "name": "muscleEndAttach",
      "mask_name": "muscleendmask",
      "mask_threshold": 0.75,
      "stiffness": 1e37,
      "dampingratio": 0.1,
      "target_path": "data/muscle/model/bicep_bone.geo"
    }
  ]
}
