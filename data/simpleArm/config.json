{
  "metainfo": {
    "description": "1-DOF elbow joint with single muscle, for multi-solver comparison (OpenSim/MuJoCo/VBD/XPBD)",
    "used_by": [
      "examples/example_xpbd_coupled_simple_arm.py",
      "examples/example_mujoco_simple_arm.py",
      "examples/example_vbd_coupled_simple_arm.py",
      "scripts/osim_simple_arm.py",
      "scripts/run_simple_arm_comparison.py",
      "tests/test_xpbd_simple_arm.py"
    ],
    "created": "2026-03-30"
  },
  "geometry": {
    "humerus_length": 1.0,
    "radius_length": 1.0,
    "muscle_origin_on_humerus": [0, 0.8, 0],
    "muscle_insertion_on_radius": [0, 0.7, 0],
    "muscle_radius": 0.02,
    "n_circumferential": 8,
    "n_axial": 20
  },
  "muscle": {
    "max_isometric_force": 200.0,
    "optimal_fiber_length": 0.6,
    "tendon_slack_length": 0.55,
    "max_contraction_velocity": 10.0,
    "fiber_damping": 0.5
  },
  "activation": {
    "excitation_start_time": 0.5,
    "excitation_end_time": 3.0,
    "excitation_off": 0.3,
    "excitation_on": 1.0,
    "tau_act": 0.015,
    "tau_deact": 0.060
  },
  "solver": {
    "dt": 0.01,
    "n_steps": 1000,
    "arch": "cpu"
  },
  "initial_conditions": {
    "elbow_angle_deg": 90.0
  },
  "coupling": {
    "spring_stiffness": 50000.0,
    "spring_damping": 10.0,
    "vbd_warmup_steps": 100,
    "vbd_quasi_static": true,
    "vbd_scale_guard_min": 0.35,
    "vbd_scale_guard_max": 1.6,
    "vbd_substeps": 20,
    "vbd_iterations": 20
  },
  "output_format": "usd",
  "xpbd": {
    "num_substeps": 30,
    "volume_stiffness": 1e6,
    "arap_stiffness": 1e6,
    "attach_origin_stiffness": 1e10,
    "attach_insertion_stiffness": 1e10,
    "warmup_steps": 10,
    "mj_per_xpbd": 10,
    "density": 1060.0,
    "veldamping": 0.02
  }
}
